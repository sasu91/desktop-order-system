# ============================================================
# desktop-order-system — Desktop client configuration
# ============================================================
# Copy this file to .env and fill in values for your environment.
# .env is gitignored; only .env.example is committed.
#
# Full reference: docs/config.md
# ============================================================

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

# Absolute path to the data directory (DB, CSV files, settings.json).
# Leave unset to use the portable default: <project_root>/data
# (falls back to %APPDATA%/DesktopOrderSystem/data if that path is read-only)
# DOS_DATA_DIR=C:\Users\you\Documents\DesktopOrderSystem\data

# Absolute path to the SQLite database file.
# Leave unset to use: <DOS_DATA_DIR>/app.db
# DOS_DB_PATH=C:\Users\you\Documents\DesktopOrderSystem\data\app.db

# Absolute path to the log directory.
# Leave unset to use the portable default: <project_root>/logs
# DOS_LOG_DIR=C:\Users\you\Documents\DesktopOrderSystem\logs

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Storage engine: sqlite (recommended) or csv (legacy fallback).
# Overrides the value stored in data/settings.json.
DOS_STORAGE_BACKEND=sqlite

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
DOS_LOG_LEVEL=INFO
