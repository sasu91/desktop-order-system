# ============================================================
# desktop-order-system — .gitignore
# ============================================================

# ---------------------------------------------------------------------------
# Environment / secrets  ← never commit real .env files
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
backend/.env.local

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl
*.spec.bak

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage cache
.pytest_cache/
.coverage
htmlcov/

# ---------------------------------------------------------------------------
# Data / runtime artefacts  (local data — not for VCS)
# ---------------------------------------------------------------------------
data/
logs/
backend/logs/
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# Log files
*.log

# ---------------------------------------------------------------------------
# PyInstaller output
# ---------------------------------------------------------------------------
dist/
build/

# ---------------------------------------------------------------------------
# Android
# ---------------------------------------------------------------------------
android/.gradle/
android/.idea/
android/build/
android/app/build/
*.apk
*.aab
local.properties

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/settings.json
*.swp
*.swo
