{
  "components": {
    "schemas": {
      "DailyUpsertRequest": {
        "properties": {
          "date": {
            "format": "date",
            "title": "Date",
            "type": "string"
          },
          "event": {
            "enum": [
              "WASTE",
              "ADJUST",
              "UNFULFILLED"
            ],
            "title": "Event",
            "type": "string"
          },
          "mode": {
            "default": "replace",
            "description": "\"replace\": set the daily total to exactly qty (idempotent). \"sum\": append qty as an additional delta.",
            "enum": [
              "sum",
              "replace"
            ],
            "title": "Mode",
            "type": "string"
          },
          "note": {
            "default": "",
            "maxLength": 500,
            "title": "Note",
            "type": "string"
          },
          "qty": {
            "description": "Units to set (replace) or add (sum).",
            "minimum": 1.0,
            "title": "Qty",
            "type": "integer"
          },
          "sku": {
            "title": "Sku",
            "type": "string"
          }
        },
        "required": [
          "date",
          "sku",
          "event",
          "qty"
        ],
        "title": "DailyUpsertRequest",
        "type": "object"
      },
      "DailyUpsertResponse": {
        "properties": {
          "date": {
            "format": "date",
            "title": "Date",
            "type": "string"
          },
          "event": {
            "title": "Event",
            "type": "string"
          },
          "mode": {
            "enum": [
              "sum",
              "replace"
            ],
            "title": "Mode",
            "type": "string"
          },
          "noop": {
            "description": "True when replace mode is called with a qty that already matches the current total.",
            "title": "Noop",
            "type": "boolean"
          },
          "note": {
            "title": "Note",
            "type": "string"
          },
          "qty_delta": {
            "description": "Units actually written to the ledger (0 if noop; negative if replace reduced the total).",
            "title": "Qty Delta",
            "type": "integer"
          },
          "qty_total": {
            "description": "Final running total for (sku, date, event) after this call.",
            "title": "Qty Total",
            "type": "integer"
          },
          "sku": {
            "title": "Sku",
            "type": "string"
          }
        },
        "required": [
          "date",
          "sku",
          "event",
          "mode",
          "qty_delta",
          "qty_total",
          "note",
          "noop"
        ],
        "title": "DailyUpsertResponse",
        "type": "object"
      },
      "EodCloseRequest": {
        "properties": {
          "client_eod_id": {
            "description": "UUID client per idempotenza.",
            "examples": [
