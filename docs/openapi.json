          "date": {
            "format": "date",
            "title": "Date",
            "type": "string"
          },
          "entries": {
            "items": {
              "$ref": "#/components/schemas/EodEntry"
            },
            "minItems": 1,
            "title": "Entries",
            "type": "array"
          }
