# ============================================================
# desktop-order-system — Backend API configuration
# ============================================================
# Copy this file to backend/.env and fill in values.
# .env is gitignored; only .env.example is committed.
#
# Full reference: docs/config.md
# ============================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Absolute path to the SQLite file the API reads.
# Point this at the same file the desktop client uses.
# REQUIRED — the API will refuse to start if this is not set.
DOS_DB_PATH=/path/to/your/data/app.db

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Interface Uvicorn binds to.
# Use 127.0.0.1 (local only) or 0.0.0.0 (all interfaces).
DOS_API_HOST=127.0.0.1

# TCP port the API listens on.
DOS_API_PORT=8000

# ---------------------------------------------------------------------------
# Security  ← NEVER commit real values; use secrets manager in production
# ---------------------------------------------------------------------------

# Static bearer token for API authentication.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
DOS_API_TOKEN=CHANGE_ME_generate_a_random_token

# Secret key for JWT signing / HMAC.
# Generate: openssl rand -hex 32
DOS_SECRET_KEY=CHANGE_ME_generate_a_random_secret

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated list of allowed origins for cross-origin requests.
# Example for local Android emulator + web dev server:
# DOS_CORS_ORIGINS=http://localhost,http://10.0.2.2,http://localhost:3000
DOS_CORS_ORIGINS=http://localhost

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
DOS_LOG_LEVEL=INFO

# Directory where the API writes its log files.
# Leave unset to default to: backend/logs
# DOS_LOG_DIR=/var/log/desktop-order-system
